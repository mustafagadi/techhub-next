# Copy this file to .env.staging (in this deploy/ folder) and fill in real values. Never commit
# .env.staging itself. This .example file has no real values and is safe to commit/share.
#
# Used by: docker compose -f deploy/docker-compose.staging.yml --env-file deploy/.env.staging up -d --build

# ── Image tag (recommended: the commit SHA being deployed) ─────────────────
# IMAGE_TAG=$(git rev-parse --short HEAD)

# ── Port / bind address (optional — defaults shown) ─────────────────────────
# PORT=3000
# Localhost-only by default (TLS terminates at a reverse proxy). Set 0.0.0.0 only if that proxy
# runs on a different machine.
# BIND_ADDRESS=127.0.0.1

# ── Backend origin — point these at the STAGING backend instance ───────────
# BACKEND_URL is baked into the build (client bundle + Next rewrites) — changing it requires a
# rebuild, not just a restart. API_BASE_SERVER is read at runtime by server components.
BACKEND_URL=http://CHANGE_ME:8080
NEXT_PUBLIC_API_BASE=/api
API_BASE_SERVER=http://CHANGE_ME:8080/api

# ── Optional ─────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_GA_ID=
