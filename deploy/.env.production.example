# Copy this file to .env.production (in this deploy/ folder) and fill in real values. Never commit
# .env.production itself. This .example file has no real values and is safe to commit/share.
#
# Used by: docker compose -f deploy/docker-compose.production.yml --env-file deploy/.env.production up -d --build

# ── Image tag (recommended: the commit SHA being deployed) ─────────────────
# IMAGE_TAG=$(git rev-parse --short HEAD)

# ── Port / bind address (optional — defaults shown) ─────────────────────────
# PORT=3000
# BIND_ADDRESS=127.0.0.1

# ── Backend origin — point these at the PRODUCTION backend instance ────────
# BACKEND_URL is baked into the build (client bundle + Next rewrites) — changing it requires a
# rebuild, not just a restart. API_BASE_SERVER is read at runtime by server components.
BACKEND_URL=http://CHANGE_ME:8080
NEXT_PUBLIC_API_BASE=/api
API_BASE_SERVER=http://CHANGE_ME:8080/api

# ── Optional ─────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_GA_ID=
