# Variables for `docker compose up` — copy to .env and adjust per environment.
# (Separate from .env.local.example, which is for `next dev`.)

# Build-time — baked into the image, requires a rebuild to change.
BACKEND_URL=http://localhost:5080
NEXT_PUBLIC_API_BASE=/api
NEXT_PUBLIC_GA_ID=

# Runtime — read by server components, can change without rebuilding.
API_BASE_SERVER=http://localhost:5080/api

# Host port to publish the container on.
PORT=3000
